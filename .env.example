# OpenAI API Key for Vision-based resume extraction
OPENAI_API_KEY=sk-your-openai-api-key-here

# DataSort Dashboard Credentials
DATASORT_USER_ID=your-user-id
DATASORT_PASSWORD=your-password

# Agent Configuration
HEADLESS=false
CONTINUOUS_MODE=true
HUMAN_LIKE_DELAY=true
MIN_DELAY_MS=200
MAX_DELAY_MS=800
SUBMIT_AFTER_FILL=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/agent.log

# OCR Fallback (used when OpenAI Vision is unavailable)
USE_OCR_FALLBACK=true

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=2000
